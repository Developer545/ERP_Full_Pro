// ERP Full Pro — Prisma Schema
// Version: 1.0.0 — Foundation
//
// Convenciones:
// - IDs: cuid() (corto, seguro, sorteable cronologicamente)
// - Todos los modelos: audit columns (createdAt, updatedAt, createdBy, updatedBy)
// - Todos los modelos: soft delete (deletedAt, isActive)
// - Todos los modelos: @@index([tenantId, isActive]) para performance
// - Tablas BD: snake_case plural con @@map()
// - Para agregar columna: agregar campo aqui + npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// TENANTS (Empresas)
// ============================================================

model Tenant {
  id     String       @id @default(cuid())
  name   String
  slug   String       @unique // URL: app.com/[slug]/dashboard
  plan   Plan         @default(FREE)
  status TenantStatus @default(TRIAL)

  // Configuracion (JSON flexible para agregar campos sin migrar)
  settings  Json @default("{}") // TenantSettings
  dteConfig Json? // DTEConfig El Salvador

  // Limites por plan
  maxUsers             Int @default(2)
  maxProducts          Int @default(50)
  maxInvoicesPerMonth  Int @default(20)

  // Suscripcion
  trialEndsAt     DateTime?
  subscriptionId  String?

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relaciones
  users         User[]
  products      Product[]
  categories    Category[]
  customers     Customer[]
  suppliers     Supplier[]
  invoices           Invoice[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  inventoryMovements InventoryMovement[]
  accountReceivables  AccountReceivable[]
  purchaseOrders      PurchaseOrder[]
  accountsPayable     AccountPayable[]
  expenseCategories   ExpenseCategory[]
  expenses            Expense[]
  employees           Employee[]
  planillas           Planilla[]

  @@map("tenants")
}

enum Plan {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  PENDING_DELETION
}

// ============================================================
// USUARIOS Y AUTH
// ============================================================

model User {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  email    String
  name     String
  password String   // bcrypt hash
  role     UserRole @default(SELLER)
  avatar   String?

  // 2FA (preparado, no obligatorio inicialmente)
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  backupCodes      String[] // Hashed backup codes

  // Estado
  isActive          Boolean   @default(true)
  lastLoginAt       DateTime?
  mustChangePassword Boolean  @default(false)

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  deletedAt DateTime?

  // Relaciones
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@unique([tenantId, email])
  @@index([tenantId, isActive])
  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SELLER
  ACCOUNTANT
  VIEWER
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  refreshToken String   @unique // Hash del refresh token
  jti          String   @unique // JWT ID para invalidacion
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String  @id @default(cuid())
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id])
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  action     String  // "PRODUCT_CREATE", "INVOICE_CANCEL", "USER_LOGIN"
  entityType String  // "Product", "Invoice", "User"
  entityId   String?
  oldData    Json?   // Snapshot antes del cambio
  newData    Json?   // Snapshot despues del cambio
  ipAddress  String?
  userAgent  String?
  metadata   Json?   // Datos extra segun el contexto

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, userId])
  @@map("audit_logs")
}

// ============================================================
// PRODUCTOS Y CATEGORIAS
// ============================================================

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  color       String?   // Para UI (hex)
  parentId    String?   // Para categorias anidadas
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  products Product[]

  @@index([tenantId, isActive])
  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  name        String
  description String?
  sku         String?   // Codigo interno
  barcode     String?   // Codigo de barras
  unit        String    @default("unidad") // unidad, kg, litro, caja, etc
  image       String?   // URL Cloudinary

  // Precios
  price       Decimal   @db.Decimal(12, 2) // Precio de venta (con IVA incluido)
  cost        Decimal   @default(0) @db.Decimal(12, 2) // Costo de compra
  taxRate     Decimal   @default(0.13) @db.Decimal(5, 4) // 0.13 = 13% IVA

  // Inventario
  stock       Decimal   @default(0) @db.Decimal(12, 3)
  minStock    Decimal   @default(0) @db.Decimal(12, 3) // Alerta de stock bajo
  maxStock    Decimal?  @db.Decimal(12, 3)
  trackStock  Boolean   @default(true)

  // Audit
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
  deletedBy String?

  inventoryMovements InventoryMovement[]

  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
  @@index([tenantId, isActive])
  @@index([tenantId, categoryId])
  @@index([tenantId, stock])
  @@map("products")
}

// ============================================================
// CLIENTES
// ============================================================

model Customer {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  // Datos personales/empresa
  name         String
  docType      DocType  @default(DUI) // DUI, NIT, PASAPORTE, NRC
  docNumber    String?
  email        String?
  phone        String?
  address      String?
  city         String?
  department   String?
  country      String  @default("SV")

  // DTE
  nit          String? // Para CCF
  nrc          String? // Para credito fiscal
  actividadEconomica String?

  // Credito
  creditLimit  Decimal @default(0) @db.Decimal(12, 2)
  creditDays   Int     @default(0) // Dias de credito

  notes    String?

  // Audit
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  invoices           Invoice[]
  accountReceivables AccountReceivable[]

  @@index([tenantId, isActive])
  @@index([tenantId, docNumber])
  @@map("customers")
}

enum DocType {
  DUI
  NIT
  PASAPORTE
  NRC
  OTRO
}

// ============================================================
// PROVEEDORES
// ============================================================

model Supplier {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])

  name        String
  nit         String?
  nrc         String?
  email       String?
  phone       String?
  address     String?
  contactName String?

  // Condiciones comerciales
  paymentDays Int     @default(0)
  creditLimit Decimal @default(0) @db.Decimal(12, 2)

  notes String?

  // Audit
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  products        Product[]
  purchaseOrders  PurchaseOrder[]
  accountsPayable AccountPayable[]

  @@index([tenantId, isActive])
  @@map("suppliers")
}

// ============================================================
// FACTURAS (estructura base — se expande en Fase 2)
// ============================================================

model Invoice {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  customerId String?
  customer   Customer?     @relation(fields: [customerId], references: [id])

  // DTE
  tipoDoc    TipoDocumento @default(CCF)
  correlativo String
  codigoGeneracion String @unique // UUID generado para MH
  selloRecibido String?   // Sello del MH

  // Totales
  subtotal   Decimal @db.Decimal(12, 2)
  descuento  Decimal @default(0) @db.Decimal(12, 2)
  ivaDebito  Decimal @db.Decimal(12, 2)
  total      Decimal @db.Decimal(12, 2)

  // Estado
  status     InvoiceStatus @default(DRAFT)
  paymentMethod PaymentMethod @default(CASH)
  notes      String?

  // Audit
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  items             InvoiceItem[]
  accountReceivable AccountReceivable?

  @@index([tenantId, isActive])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@unique([tenantId, tipoDoc, correlativo])
  @@map("invoices")
}

model InvoiceItem {
  id         String  @id @default(cuid())
  invoiceId  String
  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  productId  String?

  description String
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  taxRate     Decimal @default(0.13) @db.Decimal(5, 4)
  subtotal    Decimal @db.Decimal(12, 2)
  ivaAmount   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_items")
}

enum TipoDocumento {
  CCF  // Comprobante de Credito Fiscal
  CF   // Consumidor Final
  NC   // Nota de Credito
  ND   // Nota de Debito
  FE   // Factura de Exportacion
  FSE  // Factura de Sujeto Excluido
}

enum InvoiceStatus {
  DRAFT       // Borrador
  SENT        // Enviado a MH
  ACCEPTED    // Aceptado por MH
  REJECTED    // Rechazado por MH
  CANCELLED   // Anulado
}

enum PaymentMethod {
  CASH        // Efectivo
  CARD        // Tarjeta
  TRANSFER    // Transferencia
  CHECK       // Cheque
  CREDIT      // Credito
  MIXED       // Mixto
}

// ============================================================
// INVENTARIO / KARDEX
// ============================================================

model InventoryMovement {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  type          MovementType
  quantity      Decimal  @db.Decimal(12, 3)  // Positivo = entrada, negativo = salida
  unitCost      Decimal  @default(0) @db.Decimal(12, 2)
  previousStock Decimal  @db.Decimal(12, 3)
  newStock      Decimal  @db.Decimal(12, 3)

  // Referencia al origen del movimiento
  referenceType  String?   // "INVOICE", "PURCHASE", "ADJUSTMENT", "INITIAL"
  referenceId    String?   // ID de la factura/compra/etc.
  reason         String?   // Descripcion libre

  createdAt DateTime @default(now())
  createdBy String?

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@index([tenantId, referenceType, referenceId])
  @@map("inventory_movements")
}

enum MovementType {
  ENTRY        // Entrada (compra, ajuste positivo)
  EXIT         // Salida (venta, ajuste negativo)
  ADJUSTMENT   // Ajuste manual
  TRANSFER     // Transferencia entre bodegas
  INITIAL      // Stock inicial
  RETURN       // Devolucion
}

// ============================================================
// CUENTAS POR COBRAR (CxC)
// ============================================================

model AccountReceivable {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  invoiceId  String?  @unique
  invoice    Invoice? @relation(fields: [invoiceId], references: [id])

  amount    Decimal  @db.Decimal(12, 2) // Monto total
  paid      Decimal  @default(0) @db.Decimal(12, 2) // Pagado
  balance   Decimal  @db.Decimal(12, 2) // Saldo pendiente

  dueDate   DateTime // Fecha de vencimiento
  status    CxCStatus @default(PENDING)
  notes     String?

  // Audit
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  payments  AccountReceivablePayment[]

  @@index([tenantId, isActive])
  @@index([tenantId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, dueDate])
  @@map("accounts_receivable")
}

model AccountReceivablePayment {
  id                  String            @id @default(cuid())
  accountReceivableId String
  accountReceivable   AccountReceivable @relation(fields: [accountReceivableId], references: [id])

  amount        Decimal      @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  reference     String?      // Numero cheque, transferencia, etc.
  notes         String?

  createdAt DateTime @default(now())
  createdBy String?

  @@index([accountReceivableId])
  @@map("ar_payments")
}

enum CxCStatus {
  PENDING   // Pendiente
  PARTIAL   // Pago parcial
  PAID      // Pagado
  OVERDUE   // Vencido
  CANCELLED // Anulado
}

// ============================================================
// COMPRAS — Ordenes de Compra (Fase 3)
// ============================================================

model PurchaseOrder {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  // Identificacion
  numero    String  // Correlativo interno: "OC-00000001"
  reference String? // Referencia del proveedor (factura, nota de envio, etc.)

  // Totales
  subtotal  Decimal @default(0) @db.Decimal(12, 2)
  descuento Decimal @default(0) @db.Decimal(12, 2)
  iva       Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @default(0) @db.Decimal(12, 2)

  // Fechas
  fechaOrden    DateTime  @default(now())
  fechaEsperada DateTime?
  fechaRecibida DateTime?

  status PurchaseStatus @default(DRAFT)
  notes  String?

  // Audit
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  items           PurchaseOrderItem[]
  accountsPayable AccountPayable[]

  @@index([tenantId, isActive])
  @@index([tenantId, status])
  @@index([tenantId, supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])

  productId   String?
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitCost    Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  taxRate     Decimal @default(0.13) @db.Decimal(5, 4)
  subtotal    Decimal @db.Decimal(12, 2)
  ivaAmount   Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  // Recepcion parcial
  quantityReceived Decimal @default(0) @db.Decimal(10, 3)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

enum PurchaseStatus {
  DRAFT     // Borrador
  SENT      // Enviada al proveedor
  PARTIAL   // Recibida parcialmente
  RECEIVED  // Recibida completa
  CANCELLED // Cancelada
}

// ============================================================
// CxP — Cuentas por Pagar (Fase 3)
// ============================================================

model AccountPayable {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  supplierId      String
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  // Datos del documento
  documento  String  // Referencia de la factura del proveedor
  descripcion String?

  // Montos
  montoTotal    Decimal @db.Decimal(12, 2)
  montoPagado   Decimal @default(0) @db.Decimal(12, 2)
  montoPendiente Decimal @db.Decimal(12, 2)

  // Fechas
  fechaEmision    DateTime @default(now())
  fechaVencimiento DateTime

  status CxPStatus @default(PENDING)
  notes  String?

  // Audit
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  payments AccountPayablePayment[]

  @@index([tenantId, isActive])
  @@index([tenantId, status])
  @@index([tenantId, supplierId])
  @@index([tenantId, fechaVencimiento])
  @@map("accounts_payable")
}

model AccountPayablePayment {
  id               String         @id @default(cuid())
  accountPayableId String
  accountPayable   AccountPayable @relation(fields: [accountPayableId], references: [id])

  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  reference     String?
  notes         String?

  createdAt DateTime @default(now())
  createdBy String?

  @@index([accountPayableId])
  @@map("ap_payments")
}

enum CxPStatus {
  PENDING   // Pendiente
  PARTIAL   // Pago parcial
  PAID      // Pagado
  OVERDUE   // Vencido
  CANCELLED // Anulado
}

// ============================================================
// GASTOS (Fase 3)
// ============================================================

model ExpenseCategory {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name  String
  color String? // Hex color para UI

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  createdBy String?
  deletedAt DateTime?

  expenses Expense[]

  @@index([tenantId, isActive])
  @@map("expense_categories")
}

model Expense {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  categoryId String?
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id])

  descripcion   String
  monto         Decimal @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(CASH)
  reference     String? // Numero recibo, factura, etc.
  fecha         DateTime @default(now())

  // Comprobante (URL Cloudinary)
  comprobanteUrl String?

  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?

  @@index([tenantId, isActive])
  @@index([tenantId, categoryId])
  @@index([tenantId, fecha])
  @@map("expenses")
}

// ============================================================
// NOTIFICACIONES IN-APP
// ============================================================

model Notification {
  id       String   @id @default(cuid())
  tenantId String
  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  userId   String
  user     User     @relation(fields: [userId], references: [id])

  type    String  // "STOCK_LOW", "INVOICE_OVERDUE", "SYSTEM"
  title   String
  message String
  data    Json?   // { entityType, entityId, url }
  read    Boolean  @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([tenantId, userId, read])
  @@index([tenantId, userId, createdAt])
  @@map("notifications")
}

// ============================================================
// RRHH — EMPLEADOS + PLANILLA
// ============================================================

enum TipoContrato {
  INDEFINIDO
  PLAZO_FIJO
  TEMPORAL
  HONORARIOS
}

enum EstadoEmpleado {
  ACTIVO
  INACTIVO
  LICENCIA
  SUSPENDIDO
}

enum TipoAFP {
  CRECER
  CONFÍA
}

enum EstadoPlanilla {
  BORRADOR
  CERRADA
  PAGADA
}

model Employee {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  // Datos personales
  firstName       String
  lastName        String
  dui             String?   // Documento Unico de Identidad
  nit             String?
  nss             String?   // Numero Seguro Social (ISSS)
  nup             String?   // Numero Unico Previsional (AFP)
  email           String?
  phone           String?
  address         String?
  birthDate       DateTime?
  gender          String?   // M / F

  // Datos laborales
  cargo           String
  departamento    String?
  fechaIngreso    DateTime
  tipoContrato    TipoContrato @default(INDEFINIDO)
  estado          EstadoEmpleado @default(ACTIVO)

  // Remuneracion
  salarioBase     Decimal  @db.Decimal(12, 2)
  tipoAFP         TipoAFP  @default(CONFÍA)

  // Configuracion deducciones (porcentajes custom si aplica)
  exentoISS       Boolean  @default(false)
  exentoAFP       Boolean  @default(false)
  exentoRenta     Boolean  @default(false)

  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?

  planillaDetalles PlanillaDetalle[]

  @@index([tenantId, isActive])
  @@index([tenantId, estado])
  @@map("employees")
}

model Planilla {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  periodo         String   // "2026-03" formato YYYY-MM
  mes             Int      // 1-12
  anio            Int
  estado          EstadoPlanilla @default(BORRADOR)

  // Totales calculados
  empleadosCount  Int      @default(0)
  totalBruto      Decimal  @db.Decimal(12, 2) @default(0)
  totalISS        Decimal  @db.Decimal(12, 2) @default(0)  // ISSS empleado
  totalAFP        Decimal  @db.Decimal(12, 2) @default(0)  // AFP empleado
  totalRenta      Decimal  @db.Decimal(12, 2) @default(0)  // ISR retenido
  totalDescuentos Decimal  @db.Decimal(12, 2) @default(0)
  totalNeto       Decimal  @db.Decimal(12, 2) @default(0)

  // Aporte patronal (gasto de la empresa)
  totalISSPatronal Decimal @db.Decimal(12, 2) @default(0)
  totalAFPPatronal Decimal @db.Decimal(12, 2) @default(0)
  totalINSAFORP    Decimal @db.Decimal(12, 2) @default(0)

  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?

  detalles        PlanillaDetalle[]

  @@unique([tenantId, periodo])
  @@index([tenantId, anio, mes])
  @@map("planillas")
}

model PlanillaDetalle {
  id          String   @id @default(cuid())
  planillaId  String
  planilla    Planilla @relation(fields: [planillaId], references: [id])
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])

  // Devengos
  salarioBase     Decimal  @db.Decimal(12, 2)
  diasTrabajados  Int      @default(30)
  horasExtra      Decimal  @db.Decimal(12, 2) @default(0)
  bonos           Decimal  @db.Decimal(12, 2) @default(0)
  comisiones      Decimal  @db.Decimal(12, 2) @default(0)
  otrosIngresos   Decimal  @db.Decimal(12, 2) @default(0)
  totalBruto      Decimal  @db.Decimal(12, 2)

  // Deducciones empleado
  descuentoISS    Decimal  @db.Decimal(12, 2) @default(0)  // 3%
  descuentoAFP    Decimal  @db.Decimal(12, 2) @default(0)  // 7.25%
  descuentoRenta  Decimal  @db.Decimal(12, 2) @default(0)  // ISR tabla
  otrasDeduciones Decimal  @db.Decimal(12, 2) @default(0)
  totalDescuentos Decimal  @db.Decimal(12, 2)
  salarioNeto     Decimal  @db.Decimal(12, 2)

  // Aporte patronal (no descuenta al empleado)
  issPatronal     Decimal  @db.Decimal(12, 2) @default(0)  // 7.5%
  afpPatronal     Decimal  @db.Decimal(12, 2) @default(0)  // 8.75%
  insaforp        Decimal  @db.Decimal(12, 2) @default(0)  // 1%

  createdAt       DateTime @default(now())

  @@unique([planillaId, employeeId])
  @@index([planillaId])
  @@index([employeeId])
  @@map("planilla_detalles")
}

// ============================================================
// CONTABILIDAD
// ============================================================

/// Tipos de cuenta del catálogo contable PYMES El Salvador
enum TipoCuenta {
  ACTIVO
  PASIVO
  CAPITAL       // Patrimonio neto / Capital contable
  PATRIMONIO    // Alias contable formal de CAPITAL
  INGRESO
  COSTO
  GASTO
  CIERRE        // Cuentas de cierre del ejercicio
  ORDEN_DEUDORA   // Cuentas de orden deudora (memorandum)
  ORDEN_ACREEDORA // Cuentas de orden acreedora (memorandum)
}

/// Estado del período contable
enum EstadoPeriodo {
  ABIERTO  // Acepta nuevos asientos
  CERRADO  // Bloqueado — no acepta asientos
}

/// Naturaleza del saldo de la cuenta
enum NaturalezaCuenta {
  DEUDORA  // Se debita para aumentar (Activo, Costo, Gasto)
  ACREEDORA // Se acredita para aumentar (Pasivo, Capital, Ingreso)
}

/// Estado de un asiento contable
enum EstadoAsiento {
  BORRADOR   // Editable, no afecta saldos
  PUBLICADO  // Firme, afecta saldos — no editable
  ANULADO    // Reversado
}

/// Origen de la partida automática
enum OrigenAsiento {
  MANUAL       // Creado por el usuario
  FACTURA_DTE  // Generado desde Factura DTE (POS / facturación)
  COMPRA       // Generado desde Orden de Compra recibida
  PLANILLA     // Generado desde Planilla mensual
  GASTO        // Generado desde módulo de Gastos
  AGUINALDO    // Generado desde cálculo de Aguinaldo
}

/// Catálogo de cuentas contables del tenant (Plan de cuentas PYMES SV)
model AccountChart {
  id        String   @id @default(cuid())
  tenantId  String

  codigo    String              // "1.1.1.01" — código jerárquico libre
  nombre    String
  tipo      TipoCuenta
  naturaleza NaturalezaCuenta
  nivel     Int                 // 1=mayor, 2=submajor, 3=analítica...
  parentId  String?             // Cuenta padre (null = raíz)
  parent    AccountChart?       @relation("CuentaHijos", fields: [parentId], references: [id])
  hijos     AccountChart[]      @relation("CuentaHijos")

  permiteMovimiento Boolean     @default(true)  // false = solo agrupadora
  notas     String?

  lines     JournalLine[]
  balances  AccountBalance[]

  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([tenantId, codigo])
  @@index([tenantId, isActive])
  @@index([tenantId, tipo])
  @@map("account_charts")
}

/// Cabecera del asiento contable (Diario General)
model JournalEntry {
  id        String   @id @default(cuid())
  tenantId  String

  numero    Int               // Correlativo por tenant/año
  anio      Int
  fecha     DateTime
  concepto  String
  tipo      String   @default("DIARIO") // DIARIO, AJUSTE, CIERRE, APERTURA
  estado    EstadoAsiento     @default(BORRADOR)
  origen    OrigenAsiento     @default(MANUAL)
  origenId  String?           // ID del documento origen (invoiceId, purchaseOrderId, etc.)

  // Período contable al que pertenece (opcional para compatibilidad)
  periodoId String?
  periodo   AccountingPeriod? @relation(fields: [periodoId], references: [id])

  totalDebe  Decimal @db.Decimal(14, 2) @default(0)
  totalHaber Decimal @db.Decimal(14, 2) @default(0)

  lines     JournalLine[]

  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([tenantId, anio, numero])
  @@index([tenantId, isActive])
  @@index([tenantId, fecha])
  @@index([tenantId, estado])
  @@index([tenantId, origen, origenId])
  @@index([tenantId, periodoId])
  @@map("journal_entries")
}

/// Líneas del asiento (débitos y créditos)
model JournalLine {
  id            String   @id @default(cuid())
  entryId       String
  entry         JournalEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId     String
  account       AccountChart  @relation(fields: [accountId], references: [id])

  descripcion   String?
  debe          Decimal @db.Decimal(14, 2) @default(0)
  haber         Decimal @db.Decimal(14, 2) @default(0)
  orden         Int     @default(0)

  createdAt     DateTime @default(now())

  @@index([entryId])
  @@index([accountId])
  @@map("journal_lines")
}

/// Período contable mensual (controla qué meses aceptan asientos)
model AccountingPeriod {
  id         String         @id @default(cuid())
  tenantId   String

  nombre     String         // "Enero 2026"
  anio       Int
  mes        Int            // 1-12
  fechaInicio DateTime
  fechaFin    DateTime
  estado     EstadoPeriodo  @default(ABIERTO)

  entries    JournalEntry[]
  balances   AccountBalance[]

  isActive   Boolean  @default(true)
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?

  @@unique([tenantId, anio, mes])
  @@index([tenantId, isActive])
  @@index([tenantId, estado])
  @@map("accounting_periods")
}

/// Saldo acumulado por cuenta en cada período (desnormalizado para reportes rápidos)
model AccountBalance {
  id          String  @id @default(cuid())
  tenantId    String

  accountId   String
  account     AccountChart     @relation(fields: [accountId], references: [id])
  periodoId   String
  periodo     AccountingPeriod @relation(fields: [periodoId], references: [id])

  saldoAnterior Decimal @db.Decimal(14, 2) @default(0)
  debitos       Decimal @db.Decimal(14, 2) @default(0)
  creditos      Decimal @db.Decimal(14, 2) @default(0)
  saldoFinal    Decimal @db.Decimal(14, 2) @default(0)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([accountId, periodoId])
  @@index([tenantId])
  @@index([tenantId, periodoId])
  @@map("account_balances")
}

/// Tipos de asiento configurables por tenant
model JournalType {
  id       String  @id @default(cuid())
  tenantId String?  // null = predefinido del sistema; String = personalizado por tenant

  nombre   String   // DIARIO, AJUSTE, CIERRE, APERTURA, o personalizado
  color    String   @default("blue")
  activo   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@map("journal_types")
}

# ============================================
# ERP Full Pro — Variables de Entorno (ejemplo)
# ============================================
# Copiar como .env.local y completar los valores

# Base de datos (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth JWT
JWT_SECRET="generar-64-chars-aleatorios"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ERP Full Pro"

# Upstash Redis (opcional — cache L2)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Email (Resend)
# RESEND_API_KEY=""

# Cloudinary (imagenes)
# CLOUDINARY_URL=""

# Sentry (error tracking)
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_DSN=""

# Vercel Cron Secret
# CRON_SECRET=""

# Panel superadmin externo
# ERP_SUPERADMIN_API_KEY="generar-una-clave-larga-y-segura"
